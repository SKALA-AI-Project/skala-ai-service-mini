OPENAI_API_KEY= # Your OpenAI API key goes here
LANGCHAIN_API_KEY= # Your LangSmith API key goes here
LANGCHAIN_TRACING_V2=true # Set to true to enable LangSmith tracing, which provides detailed insights into your LangChain interactions.
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com # The endpoint for LangSmith API. You can change this if you are using a different deployment or environment.
LANGCHAIN_PROJECT=SKALA # The name of your LangSmith project. This is used to organize your traces and insights within the LangSmith dashboard.
HUGGINGFACEHUB_API_TOKEN= # Your Hugging Face Hub API token goes here
TAVILY_API_KEY= # Your Tavily API key goes here